# ── AWS Credentials ──────────────────────────────────────────────
# Get FREE credentials at: aws.amazon.com/free (no credit card required for free tier)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1

# ── AWS DynamoDB ──────────────────────────────────────────────────
# Auto-created by running backend/aws_setup.py — no manual action needed

# ── AWS SNS (SMS alerts) ──────────────────────────────────────────
# Auto-created by running backend/aws_setup.py
SNS_TOPIC_ARN=

# ── SMS Alerts Configuration ──────────────────────────────────────
# Enter your mobile number with country code (e.g. +919XXXXXXXXX)
# When set, SMS violation alerts will be sent directly to this number.
ALERT_PHONE_NUMBER=

# ── AWS SES (Email alerts) ────────────────────────────────────────
# Verify your sender email at AWS Console → SES → Verified Identities
SES_FROM_EMAIL=your_sender_email@example.com
# The destination email address where violation alert emails will be sent
ALERT_EMAIL=your_destination_email@example.com

# ── AWS IoT Core ──────────────────────────────────────────────────
# Auto-discovered and written to this file by running backend/aws_setup.py
IOT_ENDPOINT=

# ── AWS S3 ────────────────────────────────────────────────────────
# Change this to a globally unique name for your own deployment
S3_BUCKET=highbeam-detection-unique-bucket-name

# ── Hardware / Simulator Configuration ─────────────────────────────
# Set to the COM port of your physical ESP32 (e.g., COM3, COM4, or /dev/ttyUSB0)
SERIAL_PORT=COM3

# ── PYTHONPATH for VSCode/Pylance ─────────────────────────────────
PYTHONPATH=./backend;./dashboard

# ── AI Agents / CrewAI Configuration ──────────────────────────────
# Enter your API keys if you wish to run the AI report generator agents
OPENAI_API_KEY=your_openai_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here

# Destination email for the CrewAI generated Daily Police Reports
POLICE_EMAIL=police_department@example.com
